@model IEnumerable<Petshop.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Clientes</h1>
        <p class="text-muted mb-0">Cadastro com CPF único, ativo/desativo e pets vinculados.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo Cliente</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form class="row g-2 align-items-end" asp-action="Search" method="get">
            <div class="col-auto">
                <label for="cpfSearch" class="form-label">Buscar por CPF</label>
                <input type="text" class="form-control" id="cpfSearch" name="cpf" placeholder="Digite o CPF" maxlength="14" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Buscar</button>
            </div>
            <div class="col-auto">
                <a class="btn btn-outline-secondary" asp-action="Index">Limpar</a>
            </div>
        </form>
    </div>
</div>

@if (TempData["SearchError"] is string searchError)
{
    <div class="alert alert-warning">@searchError</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Telefone</th>
                <th>Status</th>
                <th>Pets</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>@cliente.Nome</td>
                    <td>@cliente.CPF</td>
                    <td>@cliente.Telefone</td>
                    <td>@(cliente.Ativo ? "Ativo" : "Desativado")</td>
                    <td>@(cliente.Pets?.Count ?? 0)</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@cliente.Id">Consultar</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@cliente.Id">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>