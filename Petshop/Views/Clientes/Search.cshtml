@model Petshop.Models.ClienteSearchViewModel

@{
    ViewData["Title"] = "Buscar Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Buscar Cliente</h1>
        <p class="text-muted mb-0">Informe o CPF obrigatoriamente. O nome é opcional para ajudar na pesquisa.</p>
    </div>
</div>

<div class="card search-card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row gy-4">
            <div class="col-lg-4 d-flex align-items-center justify-content-center">
                <div class="text-center px-3">
                    <img src="~/images/client-icon.svg" alt="Buscar cliente" class="search-illustration mb-3" />
                    <h2 class="h5 mb-2">Busca inteligente</h2>
                    <p class="text-muted mb-0">O CPF é obrigatório para encontrar o cliente e seus pets.</p>
                </div>
            </div>
            <div class="col-lg-8">
                <form asp-action="Search" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nome" class="form-label"></label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CPF" class="form-label"></label>
                            <input asp-for="CPF" class="form-control" maxlength="14" />
                            <span asp-validation-for="CPF" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Buscar</button>
                        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
