@model IEnumerable<Petshop.Models.Pet>

@{
    ViewData["Title"] = "Pets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Pets</h1>
        <p class="text-muted mb-0">Cadastro com MVC, SQL Server e Repository Pattern.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo Pet</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Cliente</th>
                <th>Espécie</th>
                <th>Raça</th>
                <th>Idade</th>
                <th>Status</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pet in Model)
            {
                <tr>
                    <td>@pet.Nome</td>
                    <td>@pet.Cliente?.Nome</td>
                    <td>@pet.Especie</td>
                    <td>@pet.Raca</td>
                    <td>@pet.Idade</td>
                    <td>@(pet.Ativo ? "Ativo" : "Desativado")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@pet.Id">Editar</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@pet.Id">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>