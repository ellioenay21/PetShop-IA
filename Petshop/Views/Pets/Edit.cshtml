@model Petshop.Models.Pet

@{
    ViewData["Title"] = "Editar Pet";
}

<h1 class="h3 mb-4">Editar Pet</h1>

<form asp-action="Edit" method="post" class="row g-3">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="ClienteId" class="form-label">Cliente</label>
        <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.Clientes">
            <option value="">Selecione um cliente</option>
        </select>
        <span asp-validation-for="ClienteId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Especie" class="form-label"></label>
        <input asp-for="Especie" class="form-control" />
        <span asp-validation-for="Especie" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Raca" class="form-label"></label>
        <input asp-for="Raca" class="form-control" />
        <span asp-validation-for="Raca" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Idade" class="form-label"></label>
        <input asp-for="Idade" class="form-control" />
        <span asp-validation-for="Idade" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Ativo" class="form-label"></label>
        <select asp-for="Ativo" class="form-select">
            <option value="true">Ativo</option>
            <option value="false">Desativado</option>
        </select>
        <span asp-validation-for="Ativo" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Observacoes" class="form-label"></label>
        <textarea asp-for="Observacoes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Observacoes" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Salvar alterações</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}