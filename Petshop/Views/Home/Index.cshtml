@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-light rounded-3 hero-banner shadow-sm">
    <div class="container-fluid py-5">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold">Petshop</h1>
                <p class="col-md-10 fs-5 text-secondary">Bem-vindo ao sistema de cadastro de clientes e pets. Organize informações, faça buscas rápidas e acompanhe seus clientes com praticidade.</p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a class="btn btn-primary btn-lg" asp-controller="Pets" asp-action="Index">Acessar Pets</a>
                    <a class="btn btn-outline-secondary btn-lg" asp-controller="Clientes" asp-action="Create">Cadastrar Cliente</a>
                </div>
            </div>
            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <img src="~/images/pet-icon.svg" alt="Ilustração pet" class="hero-image" />
            </div>
        </div>
    </div>
</div>
